# Doomscroller Backend Environment Variables
# Copy to .env and fill in values

# n8n webhook URL (from Wave 1 - Task 11)
N8N_WEBHOOK_URL=http://your-n8n-instance/webhook/doom

# Shared secret for n8n webhook auth (must match WEBHOOK_SECRET in n8n env vars)
WEBHOOK_SECRET=your_webhook_secret_here

# Server port
PORT=3000
